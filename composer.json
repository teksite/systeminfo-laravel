{
    "name": "teksite/systeminfo-laravel",
    "description": "A Laravel package for collecting system, server, PHP and Laravel runtime information",
    "keywords": [
        "laravel",
        "system-info",
        "monitoring",
        "server",
        "cpu",
        "ram",
        "disk",
        "php",
        "laravel-monitor"
    ],
    "authors": [
        {
            "name": "Sina Zangiband",
            "email": "sina.zangiband@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Teksite\\SystemInfo\\": "src/"
        }
    },
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Teksite\\SystemInfo\\SystemInformationProvider"
            ]
        }
    }
}
